# CSSwitch for Claude Science Linux

# Provider
CSSWITCH_PROVIDER=ark
ARK_API_KEY=

# Ports
PROXY_PORT=18991
SCIENCE_PORT=8990

# Linux Claude Science binary.
# Download: https://downloads.claude.ai/claude-science/latest/linux-x64
SCIENCE_BIN="$HOME/csswitch-science-linux/bin/claude-science"

# Bind host
# 127.0.0.1 = only local/SSH tunnel
# 0.0.0.0 = LAN/Tailscale reachable
BIND_HOST=127.0.0.1
PUBLIC_HOST=127.0.0.1

CSSWITCH_HOME="$HOME/csswitch-science-linux"
SANDBOX_HOME="$HOME/csswitch-science-linux/.sandbox/home"
