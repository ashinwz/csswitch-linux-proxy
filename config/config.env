# CSSwitch for Claude Science (MacAir)
# 复制后按需改；不要提交到 git。

# Provider
CSSWITCH_PROVIDER=ark
ARK_API_KEY=ark-68f49f19-2f9d-404a-9d35-9eccd7d0c659-dd04f

# Ports
PROXY_PORT=18991
SCIENCE_PORT=8992

# Claude Science binary
SCIENCE_BIN="$HOME/Applications/Claude Science.app/Contents/Resources/bin/claude-science"

# Bind host:
# - 127.0.0.1: 仅本机/SSH tunnel
# - 0.0.0.0: 局域网/Tailscale 都可访问
# - 或填 MacAir 的 Tailscale IP
BIND_HOST=127.0.0.1

# Browser access URL host shown by status.sh.
# iOS 访问时填 MacAir 的 Tailscale IP，例如 100.x.x.x 或 10.x.x.x
PUBLIC_HOST=100.94.50.75

# Sandbox paths
CSSWITCH_HOME="$HOME/csswitch"
SANDBOX_HOME="$HOME/csswitch/.sandbox/home"
